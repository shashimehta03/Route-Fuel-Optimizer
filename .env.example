# Fuel Route API — environment variables
#
# Copy this file to `.env` and adjust as needed:
#     cp .env.example .env
#
# `.env` is git-ignored. Every value here has a sensible default in
# config/settings.py, so the project also runs with no .env at all.

# --- Django core ----------------------------------------------------------
# Generate a real secret for anything non-local, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=dev-only-insecure-key-change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# Path to the SQLite database file (defaults to <project>/db.sqlite3).
# DJANGO_DB_PATH=/absolute/path/to/db.sqlite3

# --- Vehicle assumptions --------------------------------------------------
VEHICLE_RANGE_MILES=500
MILES_PER_GALLON=10

# --- Fuel-stop search tuning ----------------------------------------------
# Search radius around each 500-mile checkpoint (assignment allows 10-20).
SEARCH_RADIUS_MILES=15
# Widen up to this cap if no station is found inside the default radius.
MAX_SEARCH_RADIUS_MILES=60
# How close a station must be to the route line to count as "on-route".
CORRIDOR_MILES=5

# --- External services (free, no API key needed) --------------------------
# Routing provider (single call per request). Swap to a self-hosted OSRM in prod.
OSRM_BASE_URL=https://router.project-osrm.org
# Geocoder used only for free-form start/finish inputs.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
HTTP_TIMEOUT_SECONDS=15
FUEL_ROUTE_USER_AGENT=fuel-route-api/1.0 (assessment)
